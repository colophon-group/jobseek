# Database (same as apps/web)
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Auth
ADMIN_PASSWORD=your-admin-password-here
ADMIN_JWT_SECRET=your-32-char-random-secret-here

# Apify
APIFY_TOKEN=apify_api_...
APIFY_ORCHESTRATOR_ACTOR_ID=golanger/orchestrator-actor

# Optional: default orchestrator input (JSON)
# APIFY_DEFAULT_INPUT={"lookbackDays":7,"runIngestionActors":true}
