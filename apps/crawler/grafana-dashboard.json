{
  "annotations": [],
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Task Throughput (per minute)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "spanNulls": true },
          "unit": "short",
          "decimals": 1
        },
        "overrides": [
          { "matcher": { "id": "byRegexp", "options": "failed|timed_out" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byRegexp", "options": "succeeded" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        {
          "expr": "sum by (kind, status) (rate(crawler_tasks_total{app=\"jobseek\"}[$__rate_interval])) * 60",
          "legendFormat": "{{kind}} — {{status}}"
        }
      ]
    },
    {
      "title": "Success Rate",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0.9 }, { "color": "green", "value": 0.95 }] },
          "min": 0, "max": 1
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "sum(increase(crawler_tasks_total{app=\"jobseek\", status=\"succeeded\"}[$__range])) / clamp_min(sum(increase(crawler_tasks_total{app=\"jobseek\"}[$__range])), 1)",
          "legendFormat": "Overall",
          "instant": true
        }
      ]
    },
    {
      "title": "Total Tasks (since restart)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "succeeded" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "failed" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "sum(crawler_tasks_total{app=\"jobseek\", status=\"succeeded\"})",
          "legendFormat": "succeeded",
          "instant": true
        },
        {
          "expr": "sum(crawler_tasks_total{app=\"jobseek\", status!=\"succeeded\"})",
          "legendFormat": "failed",
          "instant": true
        }
      ]
    },
    {
      "title": "Monitor Duration (seconds)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 5, "spanNulls": true },
          "unit": "s"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "p99" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "p95" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "p50" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(crawler_task_duration_seconds_bucket{app=\"jobseek\", kind=\"monitor\"}[$__rate_interval])))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(crawler_task_duration_seconds_bucket{app=\"jobseek\", kind=\"monitor\"}[$__rate_interval])))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(crawler_task_duration_seconds_bucket{app=\"jobseek\", kind=\"monitor\"}[$__rate_interval])))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "title": "Scrape Duration (seconds)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 5, "spanNulls": true },
          "unit": "s"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "p99" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "p95" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "p50" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(crawler_task_duration_seconds_bucket{app=\"jobseek\", kind=\"scrape\"}[$__rate_interval])))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(crawler_task_duration_seconds_bucket{app=\"jobseek\", kind=\"scrape\"}[$__rate_interval])))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(crawler_task_duration_seconds_bucket{app=\"jobseek\", kind=\"scrape\"}[$__rate_interval])))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "title": "Monitor Queue Depth",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 15, "spanNulls": true },
          "unit": "short"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "http" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "browser" }, "properties": [{ "id": "color", "value": { "fixedColor": "purple", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        {
          "expr": "max(crawler_queue_depth{app=\"jobseek\", kind=\"monitor\", browser=\"false\"})",
          "legendFormat": "http"
        },
        {
          "expr": "max(crawler_queue_depth{app=\"jobseek\", kind=\"monitor\", browser=\"true\"})",
          "legendFormat": "browser"
        }
      ]
    },
    {
      "title": "HTTP Scraper Queue",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 15, "spanNulls": true },
          "unit": "short"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "initial" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }, { "id": "custom.lineWidth", "value": 3 }] },
          { "matcher": { "id": "byName", "options": "rescrape" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        {
          "expr": "sum(crawler_queue_depth{app=\"jobseek\", kind=\"scrape\", initial=\"true\", browser=\"false\"})",
          "legendFormat": "initial"
        },
        {
          "expr": "sum(crawler_queue_depth{app=\"jobseek\", kind=\"scrape\", initial=\"false\", browser=\"false\"})",
          "legendFormat": "rescrape"
        }
      ]
    },
    {
      "title": "Browser Scraper Queue",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 15, "spanNulls": true },
          "unit": "short"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "initial" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }, { "id": "custom.lineWidth", "value": 3 }] },
          { "matcher": { "id": "byName", "options": "rescrape" }, "properties": [{ "id": "color", "value": { "fixedColor": "purple", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        {
          "expr": "sum(crawler_queue_depth{app=\"jobseek\", kind=\"scrape\", initial=\"true\", browser=\"true\"})",
          "legendFormat": "initial"
        },
        {
          "expr": "sum(crawler_queue_depth{app=\"jobseek\", kind=\"scrape\", initial=\"false\", browser=\"true\"})",
          "legendFormat": "rescrape"
        }
      ]
    },
    {
      "title": "Concurrency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 15, "spanNulls": true },
          "unit": "short"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Active" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Queued" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        {
          "expr": "sum(crawler_tasks_active{app=\"jobseek\"})",
          "legendFormat": "Active"
        },
        {
          "expr": "sum(crawler_tasks_queued{app=\"jobseek\"})",
          "legendFormat": "Queued"
        }
      ]
    },
    {
      "title": "DB Pool",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 15, "spanNulls": true },
          "unit": "short"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "In Use" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Idle" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Total" }, "properties": [{ "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } }, { "id": "color", "value": { "fixedColor": "white", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        {
          "expr": "sum(crawler_db_pool_size{app=\"jobseek\"}) - sum(crawler_db_pool_idle{app=\"jobseek\"})",
          "legendFormat": "In Use"
        },
        {
          "expr": "sum(crawler_db_pool_idle{app=\"jobseek\"})",
          "legendFormat": "Idle"
        },
        {
          "expr": "sum(crawler_db_pool_size{app=\"jobseek\"})",
          "legendFormat": "Total"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["crawler", "jobseek"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Jobseek Crawler",
  "uid": "jobseek-crawler"
}
