{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jseek.co/schemas/labeller/extract_all.schema.json",
  "title": "Merged per-section extractions + globals",
  "description": "Output shape of the combined extractor subagent. Replaces 5 per-section calls + 1 globals call with one call. Per-section extracted shapes are validated post-hoc by validate.py against the per-kind schemas.",
  "type": "object",
  "required": ["sections", "globals"],
  "additionalProperties": false,
  "properties": {
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind", "block_ids", "extracted"],
        "additionalProperties": false,
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "company",
              "team",
              "role",
              "requirements",
              "preferred",
              "benefits",
              "application"
            ]
          },
          "block_ids": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "integer", "minimum": 0}
          },
          "extracted": {
            "type": ["object", "null"],
            "description": "Null for company/application (no structured extractor); otherwise shaped per the kind's schema under schemas/section_extract/."
          }
        }
      }
    },
    "globals": {
      "type": "object",
      "description": "See globals.schema.json; shape validated post-hoc.",
      "additionalProperties": true
    }
  }
}
