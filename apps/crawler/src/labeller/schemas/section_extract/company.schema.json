{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jseek.co/schemas/labeller/section_extract/company.schema.json",
  "title": "Company section extraction",
  "type": "object",
  "required": ["industry_tags", "size_band", "funding_stage", "mission_verbatim"],
  "additionalProperties": false,
  "properties": {
    "industry_tags": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "size_band": {
      "type": ["string", "null"],
      "enum": [
        null,
        "1-10",
        "11-50",
        "51-200",
        "201-500",
        "501-1000",
        "1001-5000",
        "5001-10000",
        "10001+"
      ]
    },
    "funding_stage": {
      "type": ["string", "null"],
      "enum": [
        null,
        "bootstrapped",
        "seed",
        "series_a",
        "series_b",
        "series_c",
        "series_d_plus",
        "public",
        "acquired",
        "family_owned",
        "cooperative",
        "state_owned",
        "subsidiary",
        "mutual",
        "nonprofit",
        "government",
        "unknown"
      ]
    },
    "mission_verbatim": {"type": ["string", "null"]}
  }
}
