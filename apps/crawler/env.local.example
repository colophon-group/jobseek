# Local development profile for crawler
#
# Copy to: apps/crawler/.env.local
# cp env.local.example .env.local

# Supabase URL in production. For local-first development we point both URLs
# to the same local Postgres instance.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/jobseek
LOCAL_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/jobseek

# Local Redis used by worker queues.
REDIS_URL=redis://localhost:6379/0

# Local Typesense (enabled when admin key is non-empty).
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL=http
TYPESENSE_ADMIN_KEY=local_dev_typesense_key

# Optional for local run-browser or WAF-routed hosts.
LIGHTPANDA_CDP_URL=
CDP_ROUTES=

# Optional if you run `crawler drain` or description uploads.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT_URL=
R2_DOMAIN_URL=
R2_BUCKET=

# Enrichment providers (set for local alert pipeline, phase 1).
# Remove or leave empty to disable enrichment.
USE_LOCAL_DESCRIPTIONS=true
ENRICH_MODE=sync
ENRICH_PROVIDER=gemini
ENRICH_MODEL=gemini-2.0-flash
ENRICH_API_KEY=your_gemini_api_key_here
ENRICH_RATE_LIMIT_RPM=15
