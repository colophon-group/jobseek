# Local development profile for web app
#
# Copy to: apps/web/.env.local
# cp env.local.example .env.local

# Database (for search + posting detail reads)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/jobseek
DATABASE_URL_UNPOOLED=postgresql://postgres:postgres@localhost:5432/jobseek

# Better Auth (required)
BETTER_AUTH_SECRET=change-this-in-local-dev
BETTER_AUTH_URL=http://localhost:3000
TRUSTED_ORIGINS=http://localhost:3000

# Typesense (required for search APIs)
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL=http
TYPESENSE_SEARCH_KEY=local_dev_typesense_key

# Optional: only needed for watchlist write operations
TYPESENSE_WRITE_KEY=local_dev_typesense_key

# Optional: if omitted, app falls back to in-memory cache + disabled rate limits
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: only needed for email delivery flows (sign-up/reset)
RESEND_API_KEY=

# Optional OAuth providers (local can run without these)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Optional: bypass auth locally and act as a fixed dev user
LOCAL_DEV_AUTH_BYPASS=false
LOCAL_DEV_AUTH_USER_ID=local-dev-user
LOCAL_DEV_AUTH_EMAIL=local-dev@example.com
LOCAL_DEV_AUTH_NAME=Local Dev
LOCAL_DEV_AUTH_USERNAME=local-dev
LOCAL_DEV_AUTH_DISPLAY_USERNAME=local-dev

# Optional: enables descriptionUrl links in job detail responses
R2_DOMAIN_URL=

# Optional: MiniMax API key for AI job summaries
MINIMAX_API_KEY=

# Optional: protects /api/cron/enrich-jobs in production (Vercel sends this automatically)
CRON_SECRET=
