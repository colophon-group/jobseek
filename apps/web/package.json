{
  "name": "@jobseek/web",
  "version": "0.1.1",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "lingui compile && next build",
    "start": "next start",
    "lint": "eslint .",
    "extract": "lingui extract",
    "compile": "lingui compile",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:push": "drizzle-kit push",
    "analyze": "ANALYZE=true next build",
    "optimize:svg": "svgo public/*.svg --multipass",
    "screenshots": "tsx script/capture-screenshots.ts",
    "notify-blog-indexnow": "tsx script/notify-blog-indexnow.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:isr": "vitest run --config vitest.isr.config.ts",
    "typecheck": "next typegen && tsc"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.888.0",
    "@formatjs/intl-localematcher": "^0.8.1",
    "@jseek/mcp-server": "workspace:*",
    "@lingui/core": "^5",
    "@lingui/macro": "^5",
    "@lingui/react": "^5",
    "@nivo/core": "^0.99.0",
    "@nivo/sankey": "^0.99.0",
    "@octokit/auth-app": "^8.2.0",
    "@octokit/rest": "^22.0.1",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/postcss": "^4.2.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.3",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "apify-client": "^2",
    "better-auth": "^1.4.18",
    "dompurify": "^3.4.0",
    "drizzle-orm": "^0.45.2",
    "gray-matter": "^4.0.3",
    "jose": "^6",
    "lucide-react": "^0.575.0",
    "negotiator": "^1.0.0",
    "next": "^16.2.3",
    "next-mdx-remote": "^6.0.0",
    "next-themes": "^0.4.6",
    "remark-gfm": "^4.0.0",
    "postgres": "^3.4.8",
    "react": "^19",
    "react-dom": "^19",
    "resend": "^6.9.2",
    "server-only": "^0.0.1",
    "sharp": "^0.34.5",
    "stripe": "^17",
    "tailwindcss": "^4.2.0",
    "typesense": "^3.0.5"
  },
  "devDependencies": {
    "@lingui/babel-plugin-lingui-macro": "^5",
    "@lingui/cli": "^5",
    "@lingui/conf": "^5.9.1",
    "@lingui/format-po": "^5",
    "@lingui/loader": "^5.9.1",
    "@next/bundle-analyzer": "^16.1.6",
    "@next/eslint-plugin-next": "^16.1.6",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/negotiator": "^0.6.4",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/ui": "^4.0.18",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.39.3",
    "happy-dom": "^20.8.9",
    "playwright": "^1.58.2",
    "svgo": "^4.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
