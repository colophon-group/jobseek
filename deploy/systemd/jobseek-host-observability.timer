[Unit]
Description=Collect Jobseek host telemetry every minute
Documentation=https://github.com/colophon-group/jobseek/blob/main/docs/16-hetzner-maintenance.md#fleet-observability

[Timer]
OnBootSec=2m
OnUnitActiveSec=60s
RandomizedDelaySec=10s
Persistent=true
AccuracySec=5s
Unit=jobseek-host-observability.service

[Install]
WantedBy=timers.target
