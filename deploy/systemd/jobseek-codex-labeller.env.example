# Install as /etc/jobseek-codex/labeller.env with mode 0640,
# owner root, group codex-runner.
#
# Do not commit real database URLs. Use a read-only local Postgres user that
# can SELECT the tables needed by apps/crawler/src/labeller/{sampling,prepare}.py.

LOCAL_DATABASE_URL=postgresql://jobseek_labeller_readonly:<password>@<postgres-host>:5432/crawler
