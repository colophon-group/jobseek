# Install as /etc/jobseek-codex/governor.env with mode 0600 or 0640.
# Do not put tokens or API keys in this file. Provision Codex auth with
# `codex login --device-auth`; it should live at
# /home/codex-runner/.codex/auth.json. Provision GitHub auth with
# `gh auth login` for the codex-runner account.

WS_REPO=colophon-group/jobseek
WS_REPO_URL=https://github.com/colophon-group/jobseek.git

PATH=/home/codex-runner/.local/bin:/usr/local/bin:/usr/bin:/bin

JOBSEEK_CODEX_DRY_RUN=true
JOBSEEK_CODEX_RUNNER_ROOT=/srv/jobseek-codex
JOBSEEK_CODEX_REPO_DIR=/srv/jobseek-codex/repo
JOBSEEK_CODEX_MAX_RUNTIME_S=5400
JOBSEEK_CODEX_KILL_GRACE_S=20

# The governor must treat the usage probe as best-effort telemetry. A non-zero
# exit, 401/403, transport error, or schema mismatch must fall back to local
# CODEX_EXEC_JSONL accounting for audit and conservative configured budgets.
JOBSEEK_CODEX_MAX_RUNS_PER_5H=50
JOBSEEK_CODEX_CONSERVATIVE_RUNS_PER_5H=5
JOBSEEK_CODEX_FAST_WEEKLY_REMAINING_PERCENT=50
JOBSEEK_CODEX_FAST_MIN_START_INTERVAL_S=360
JOBSEEK_CODEX_CONSERVATIVE_MIN_START_INTERVAL_S=3600
JOBSEEK_CODEX_MIN_5H_REMAINING_PERCENT=20
JOBSEEK_CODEX_MIN_WEEKLY_REMAINING_PERCENT=20

JOBSEEK_CODEX_MIN_DISK_FREE_GIB=5
JOBSEEK_CODEX_MIN_MEM_AVAILABLE_GIB=2
JOBSEEK_CODEX_MAX_LOAD_PER_CPU=2

JOBSEEK_CODEX_ARGS=codex exec --json --dangerously-bypass-approvals-and-sandbox
