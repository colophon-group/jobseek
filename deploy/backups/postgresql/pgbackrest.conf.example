[jobseek]
pg1-path=/var/lib/postgresql/data
pg1-port=5432
pg1-socket-path=/var/run/postgresql
pg1-user=crawler

[global]
repo1-type=sftp
repo1-path=/pgbackrest
repo1-sftp-host=<storage-box-subaccount-host>
repo1-sftp-host-port=23
repo1-sftp-host-user=<storage-box-subaccount-user>
repo1-sftp-private-key-file=/etc/jobseek-backup/id_ed25519
repo1-sftp-public-key-file=/etc/jobseek-backup/id_ed25519.pub
repo1-sftp-host-key-check-type=fingerprint
repo1-sftp-host-key-hash-type=sha256
repo1-sftp-host-fingerprint=<verified-storage-box-sha256-hex>
repo1-cipher-type=aes-256-cbc
repo1-cipher-pass=<generated-and-escrowed-secret>
repo1-retention-full=4
repo1-bundle=y
repo1-block=y
compress-type=zst
process-max=2
start-fast=y
archive-async=y
spool-path=/var/spool/pgbackrest
log-level-console=info

[global:archive-push]
process-max=2
