[jobseek]
pg1-path=/var/lib/postgresql/data
pg1-port=5432
pg1-socket-path=/var/run/postgresql
pg1-user=crawler

[global]
repo1-type=posix
repo1-path=/mnt/jobseek-postgresql-backups/pgbackrest
repo1-cipher-type=aes-256-cbc
repo1-cipher-pass=<generated-and-escrowed-secret>
repo1-retention-full=4
repo1-bundle=y
repo1-block=y
compress-type=zst
process-max=2
start-fast=y
archive-async=y
spool-path=/var/spool/pgbackrest
log-level-console=info

[global:archive-push]
process-max=2
